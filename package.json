    "artist-lab:seed-assets": "tsx scripts/seed-artist-assets.ts",
    "artist-lab:seed-no-spam-sharing": "tsx scripts/seed-artist-no-spam-sharing.ts",
    "artist-lab:seed-monthly-routine": "tsx scripts/seed-artist-monthly-routine.ts",
    "artist-lab:seed-fan-engagement": "tsx scripts/seed-artist-fan-engagement.ts",
    "artist-lab:seed-pre-release-assets": "tsx scripts/seed-artist-pre-release-assets.ts"
