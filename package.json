{
  "name": "dnbdoctor",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.8.x"
  },
  "browserslist": [
    "last 2 versions",
    "not dead"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "analyze": "ANALYZE=true next build --webpack",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "import:wordpress": "tsx scripts/wordpress-import.ts",
    "import:releases": "tsx scripts/import-wordpress-releases.ts",
    "release:set-gumroad": "tsx scripts/set-release-gumroad.ts",
    "import:artists": "tsx scripts/import-wordpress-artists.ts",
    "import:news": "tsx scripts/import-wordpress-news.ts",
    "admin:create:direct": "tsx scripts/create-admin-direct.ts",
    "import:feedback": "tsx scripts/import-wordpress-feedback.ts",
    "backfill:artistname": "tsx scripts/backfill-artistname.ts",
    "r2:setup-cors": "tsx scripts/setup-r2-cors.ts",
    "migrate:news-images": "tsx scripts/migrate-news-images-to-r2.ts",
    "newsletter:rename-vip": "tsx scripts/rename-vip-to-newsletter.ts",
    "newsletter:dedupe": "tsx scripts/merge-duplicate-subscribers.ts",
    "newsletter:dedupe:apply": "tsx scripts/merge-duplicate-subscribers.ts --apply",
    "artist-lab:seed-onboarding": "tsx scripts/seed-artist-onboarding.ts",
    "artist-lab:seed-profile-setup": "tsx scripts/seed-artist-profile-setup.ts",
